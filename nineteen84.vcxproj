<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Release|Win32">
      <Configuration>Release</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <RootNamespace>nineteen84</RootNamespace>
    <ProjectName>nineteen84</ProjectName>
  </PropertyGroup>

  <!-- Use a Makefile project type so VS just calls our build script -->
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'" Label="Configuration">
    <ConfigurationType>Makefile</ConfigurationType>
    <PlatformToolset>v143</PlatformToolset>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'">
    <!-- Command that VS runs when you press Build (Ctrl+Shift+B) -->
    <NMakeBuildCommandLine>"$(ProgramFiles(x86))\oscar64\bin\oscar64.exe" -tm=c64 -O2 -o "$(ProjectDir)nineteen84.prg" "$(ProjectDir)nineteen84.c"</NMakeBuildCommandLine>

    <!-- Ctrl+F5 / Run: build AND launch in oscar64 built-in emulator -->
    <NMakeReBuildCommandLine>"$(ProgramFiles(x86))\oscar64\bin\oscar64.exe" -tm=c64 -O2 -e "$(ProjectDir)nineteen84.c"</NMakeReBuildCommandLine>

    <!-- Clean just deletes the prg -->
    <NMakeCleanCommandLine>del /Q "$(ProjectDir)nineteen84.prg" "$(ProjectDir)nineteen84.asm" "$(ProjectDir)nineteen84.map" 2&gt;nul</NMakeCleanCommandLine>

    <NMakeOutput>$(ProjectDir)nineteen84.prg</NMakeOutput>

    <!-- IntelliSense include path so VS can resolve oscar64 headers -->
    <NMakeIncludeSearchPath>$(ProgramFiles(x86))\oscar64\include;$(ProjectDir)</NMakeIncludeSearchPath>
    <NMakePreprocessorDefinitions>__C64__;__CBM__</NMakePreprocessorDefinitions>
  </PropertyGroup>

  <ItemGroup>
    <None Include="nineteen84.c" />
    <None Include="build.bat" />
    <None Include="README.md" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />

</Project>
